{
  "name": "therapy-practice-assistant",
  "version": "0.1.0",
  "description": "Local-first, agentic practice-management assistant for a solo therapist. Spine plus four workflow modules. Notes functional, the rest scaffolded.",
  "private": true,
  "author": "Veeiy",
  "license": "MIT",
  "main": "dist/main/index.js",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed": "node scripts/seed-synthetic.mjs",
    "force-win32": "node scripts/force-win32-sdk.cjs",
    "package": "npm run build && electron-builder --win --x64",
    "postinstall": "node scripts/rebuild-native.mjs || true"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3",
    "better-sqlite3-multiple-ciphers": "^12",
    "uuid": "^11"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/uuid": "^10",
    "@vitejs/plugin-react": "^4",
    "electron": "^33",
    "electron-builder": "^25",
    "electron-vite": "^2",
    "react": "^18",
    "react-dom": "^18",
    "typescript": "^5",
    "vite": "^5",
    "vitest": "^2"
  }
}
